# ============================================
# Environment Variables for VPS/aaPanel Deployment
# ============================================
# Copy this file to .env on your server and fill in your values

# ============================================
# REQUIRED: Supabase Configuration
# ============================================
# Your self-hosted Supabase URL (e.g., https://supabase.yourdomain.com)
VITE_SUPABASE_URL=

# Supabase anon key (public, used by frontend)
VITE_SUPABASE_ANON_KEY=

# Supabase service role key (private, used by API)
SUPABASE_SERVICE_ROLE_KEY=

# ============================================
# REQUIRED: Application URL
# ============================================
# Your app URL / domain (e.g., https://app.yourdomain.com)
VITE_APP_URL=
APP_URL=

# ============================================
# REQUIRED: Facebook Configuration
# ============================================
# Facebook App credentials (from Facebook Developer Console)
VITE_FACEBOOK_APP_ID=
VITE_FACEBOOK_APP_SECRET=
FACEBOOK_APP_SECRET=
VITE_FACEBOOK_CONFIG_ID=

# ============================================
# OPTIONAL: Server Configuration
# ============================================
# Port for the Express server (default: 3000)
PORT=3000

# Node environment
NODE_ENV=production
