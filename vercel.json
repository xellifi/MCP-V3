{
    "buildCommand": "npm run build",
    "outputDirectory": "dist",
    "framework": "vite",
    "crons": [
        {
            "path": "/api/cron/form-followup",
            "schedule": "*/15 * * * *"
        }
    ],
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/$1"
        },
        {
            "source": "/((?!api/).*)",
            "destination": "/index.html"
        }
    ]
}